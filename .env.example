# Copy to .env.local and fill in. .env* (except this file) is gitignored.

# Deployer private key. NEVER commit a real one — use a throwaway key
# loaded just for the deploy broadcast.
PRIVATE_KEY=

# Arc Testnet RPC. The Foundry profile also exposes a public default,
# so this override is optional.
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Arc Testnet explorer API key for `forge script --verify`. Leave blank
# if you're skipping verification.
ARCSCAN_API_KEY=

# Used by script/RegisterAgent.s.sol — the deployed identity registry
# address and the agent manifest URI to register.
IDENTITY_REGISTRY=
METADATA_URI=
